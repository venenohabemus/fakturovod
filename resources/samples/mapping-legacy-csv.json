{
    "version": 1,
    "source": {
        "type": "csv",
        "delimiter": ";",
        "encoding": "UTF-8",
        "group_by": "cislo"
    },
    "invoice": {
        "number": "cislo",
        "type": {"from": "typ", "map": {"F": "invoice", "D": "credit_note"}, "map_default": "invoice"},
        "invoice_reference": {"from": "povodna_fa"},
        "issue_date": {"from": "vystavena", "transform": [{"type": "date", "from_format": "d.m.Y"}]},
        "due_date": {"from": "splatnost", "transform": [{"type": "date", "from_format": "d.m.Y"}]},
        "currency": {"from": "mena", "default": "EUR"},
        "vat_currency": {"from": "mena_dph"},
        "vat_exchange_rate": {"from": "kurz", "transform": [{"type": "decimal"}]},
        "prepaid_amount": {"from": "zaloha", "transform": [{"type": "decimal"}]},
        "buyer_reference": {"from": "cislo"},
        "supplier": {
            "peppol_id": {"const": "0245:0000000001"},
            "name": {"const": "Ukážkový dodávateľ s.r.o."},
            "street": {"const": "Hlavná 1"},
            "city": {"const": "Bratislava"},
            "zip": {"const": "811 01"},
            "country": {"const": "SK"},
            "company_id": {"const": "12345678"},
            "vat_id": {"const": "SK2020123457"}
        },
        "customer": {
            "peppol_id": {"const": "0245:0000000002"},
            "name": "odberatel",
            "street": "ulica",
            "city": "mesto",
            "zip": "psc",
            "country": {"const": "SK"},
            "company_id": "ico_odb",
            "vat_id": "icdph_odb"
        },
        "lines": {
            "fields": {
                "name": "polozka",
                "unit": {"from": "mj", "map": {"ks": "C62", "hod": "HUR", "kg": "KGM"}, "map_default": "C62"},
                "quantity": {"from": "mnozstvo", "transform": [{"type": "decimal"}]},
                "unit_price": {"from": "cena", "transform": [{"type": "decimal"}]},
                "vat_rate": "dph"
            }
        }
    }
}
